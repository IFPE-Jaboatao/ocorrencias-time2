# ─── Banco de Dados ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=radaracademico
DB_USER=radar_user
DB_PASS=radar_pass

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_um_segredo_forte_de_pelo_menos_64_chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ─── Magic Link ───────────────────────────────────────────────────────────────
MAGIC_LINK_SECRET=troque_por_outro_segredo_forte
MAGIC_LINK_BASE_URL=http://localhost:5173
MAGIC_LINK_TTL_MINUTES=15

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@radaracademico.com.br

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DEST=./uploads
